{
    "name": "newsolari/core",
    "description": "SolariWebOS Core — middleware, plugin system, module system, entity infrastructure",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "firebase/php-jwt": "^7.0",
        "ezyang/htmlpurifier": "^4.19"
    },
    "autoload": {
        "psr-4": {
            "NewSolari\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NewSolari\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NewSolari\\Core\\CoreServiceProvider"
            ]
        }
    }
}
